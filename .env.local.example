# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (for auth redirects in production)
# Local: http://localhost:3000
# Production: https://dispatch-flow-pascal-dignys-projects.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role (team invites via Auth Admin API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email notifications
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=DispatchFlow <notifications@yourdomain.com>

# Web Push (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@yourdomain.com
